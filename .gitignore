# ============================================================
# Multi-project Flutter/Dart workspace .gitignore
# ============================================================

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# ------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code (uncomment if you do NOT want to share launch configs)
#.vscode/

# ------------------------------------------------------------
# Flutter / Dart / Pub — applies to every project in the repo
# ------------------------------------------------------------
**/doc/api/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/build/
**/coverage/

# iOS Flutter build artefacts
**/ios/Flutter/.last_build_id

# Symbolication
app.*.symbols

# Obfuscation mapping
app.*.map.json

# ------------------------------------------------------------
# Android — applies to every project's android/ folder
# ------------------------------------------------------------
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/local.properties
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/gradle/wrapper/gradle-wrapper.jar
**/android/key.properties
**/*.keystore
**/*.jks

# ------------------------------------------------------------
# iOS / macOS — applies to every project's ios/ & macos/ folders
# ------------------------------------------------------------
**/ios/Pods/
**/ios/.symlinks/
**/macos/Pods/
**/macos/.symlinks/
**/*.xcworkspace/xcuserdata/
**/*.xcodeproj/xcuserdata/
**/DerivedData/
**/*.moved-aside
**/*.pbxuser
**/*.mode1v3
**/*.mode2v3
**/*.perspectivev3

# ------------------------------------------------------------
# Web
# ------------------------------------------------------------
**/web/.dart_tool/

# ------------------------------------------------------------
# Generated / output files
# ------------------------------------------------------------
**/out_put/
**/*.g.dart
**/*.freezed.dart
**/*.mocks.dart
**/*.gr.dart
